{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    }
  ],
  "id": null,
  "uid": "node-exporter-prod",
  "title": "Node Exporter \u2014 Host Metrics",
  "description": "CPU, memory, disk, load average and network metrics from node-exporter. Thresholds aligned with infrastructure alert rules.",
  "tags": [
    "node-exporter",
    "infrastructure",
    "production"
  ],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-3h",
    "to": "now"
  },
  "timepicker": {},
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "pluginId": "prometheus",
        "label": "Datasource",
        "hide": 0,
        "refresh": 1,
        "current": {}
      },
      {
        "name": "instance",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "label": "Instance",
        "query": "label_values(node_exporter_build_info, instance)",
        "refresh": 2,
        "sort": 1,
        "multi": false,
        "includeAll": false,
        "hide": 0,
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Overview",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 2,
      "type": "stat",
      "title": "CPU Usage",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "(1 - avg by(instance) (rate(node_cpu_seconds_total{mode=\"idle\", instance=\"$instance\"}[5m]))) * 100",
          "legendFormat": "CPU %",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 80
              },
              {
                "color": "red",
                "value": 95
              }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Memory Usage",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "(node_memory_MemTotal_bytes{instance=\"$instance\"} - node_memory_MemAvailable_bytes{instance=\"$instance\"}) / node_memory_MemTotal_bytes{instance=\"$instance\"} * 100",
          "legendFormat": "Memory %",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 85
              },
              {
                "color": "red",
                "value": 95
              }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Disk Usage (/ mount)",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "(1 - node_filesystem_avail_bytes{instance=\"$instance\", mountpoint=\"/\", fstype!~\"tmpfs|devtmpfs\"} / node_filesystem_size_bytes{instance=\"$instance\", mountpoint=\"/\", fstype!~\"tmpfs|devtmpfs\"}) * 100",
          "legendFormat": "Disk %",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 80
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "System Uptime",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "node_time_seconds{instance=\"$instance\"} - node_boot_time_seconds{instance=\"$instance\"}",
          "legendFormat": "Uptime",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        }
      }
    },
    {
      "id": 10,
      "type": "row",
      "title": "CPU",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 5
      },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "CPU Usage % (by mode)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "rate(node_cpu_seconds_total{instance=\"$instance\", mode!=\"idle\"}[5m]) * 100",
          "legendFormat": "{{mode}}",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "idle"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "green",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "iowait"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "orange",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "system"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "red",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Load Average vs CPU cores",
      "description": "Alert fires when load1 > 80% of CPU count. Red threshold line at 80%.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "node_load1{instance=\"$instance\"}",
          "legendFormat": "load 1m",
          "refId": "A"
        },
        {
          "expr": "node_load5{instance=\"$instance\"}",
          "legendFormat": "load 5m",
          "refId": "B"
        },
        {
          "expr": "node_load15{instance=\"$instance\"}",
          "legendFormat": "load 15m",
          "refId": "C"
        },
        {
          "expr": "count by(instance) (node_cpu_seconds_total{instance=\"$instance\", mode=\"idle\"})",
          "legendFormat": "CPU cores",
          "refId": "D"
        },
        {
          "expr": "count by(instance) (node_cpu_seconds_total{instance=\"$instance\", mode=\"idle\"}) * 0.8",
          "legendFormat": "80% threshold",
          "refId": "E"
        }
      ],
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 5
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "80% threshold"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "red",
                  "mode": "fixed"
                }
              },
              {
                "id": "custom.lineStyle",
                "value": {
                  "fill": "dash"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "CPU cores"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "blue",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": 20,
      "type": "row",
      "title": "Memory",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 14
      },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Memory Usage",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 15
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "node_memory_MemTotal_bytes{instance=\"$instance\"}",
          "legendFormat": "Total",
          "refId": "A"
        },
        {
          "expr": "node_memory_MemAvailable_bytes{instance=\"$instance\"}",
          "legendFormat": "Available",
          "refId": "B"
        },
        {
          "expr": "node_memory_MemTotal_bytes{instance=\"$instance\"} - node_memory_MemAvailable_bytes{instance=\"$instance\"}",
          "legendFormat": "Used",
          "refId": "C"
        },
        {
          "expr": "node_memory_Cached_bytes{instance=\"$instance\"}",
          "legendFormat": "Cached",
          "refId": "D"
        },
        {
          "expr": "node_memory_Buffers_bytes{instance=\"$instance\"}",
          "legendFormat": "Buffers",
          "refId": "E"
        }
      ],
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "Memory Usage %",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 15
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "(node_memory_MemTotal_bytes{instance=\"$instance\"} - node_memory_MemAvailable_bytes{instance=\"$instance\"}) / node_memory_MemTotal_bytes{instance=\"$instance\"} * 100",
          "legendFormat": "Memory %",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": {
          "mode": "single"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 85
              },
              {
                "color": "red",
                "value": 95
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        }
      }
    },
    {
      "id": 30,
      "type": "row",
      "title": "Disk",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 23
      },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "Disk Space (/ mount)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 24
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "node_filesystem_size_bytes{instance=\"$instance\", mountpoint=\"/\", fstype!~\"tmpfs|devtmpfs\"}",
          "legendFormat": "Total",
          "refId": "A"
        },
        {
          "expr": "node_filesystem_avail_bytes{instance=\"$instance\", mountpoint=\"/\", fstype!~\"tmpfs|devtmpfs\"}",
          "legendFormat": "Available",
          "refId": "B"
        },
        {
          "expr": "node_filesystem_size_bytes{instance=\"$instance\", mountpoint=\"/\", fstype!~\"tmpfs|devtmpfs\"} - node_filesystem_avail_bytes{instance=\"$instance\", mountpoint=\"/\", fstype!~\"tmpfs|devtmpfs\"}",
          "legendFormat": "Used",
          "refId": "C"
        }
      ],
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 32,
      "type": "timeseries",
      "title": "Disk I/O",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 24
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "rate(node_disk_read_bytes_total{instance=\"$instance\"}[5m])",
          "legendFormat": "Read {{device}}",
          "refId": "A"
        },
        {
          "expr": "rate(node_disk_written_bytes_total{instance=\"$instance\"}[5m])",
          "legendFormat": "Write {{device}}",
          "refId": "B"
        }
      ],
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 5
          }
        }
      }
    },
    {
      "id": 40,
      "type": "row",
      "title": "Network",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 32
      },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 41,
      "type": "timeseries",
      "title": "Network Traffic",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 33
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "rate(node_network_receive_bytes_total{instance=\"$instance\", device!~\"lo|veth.*|docker.*\"}[5m])",
          "legendFormat": "RX {{device}}",
          "refId": "A"
        },
        {
          "expr": "rate(node_network_transmit_bytes_total{instance=\"$instance\", device!~\"lo|veth.*|docker.*\"}[5m])",
          "legendFormat": "TX {{device}}",
          "refId": "B"
        }
      ],
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 5
          }
        }
      }
    },
    {
      "id": 42,
      "type": "timeseries",
      "title": "Network Errors & Drops",
      "description": "Alert fires when receive errors > 0 for 5m.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 33
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "rate(node_network_receive_errs_total{instance=\"$instance\"}[5m])",
          "legendFormat": "RX errors {{device}}",
          "refId": "A"
        },
        {
          "expr": "rate(node_network_transmit_errs_total{instance=\"$instance\"}[5m])",
          "legendFormat": "TX errors {{device}}",
          "refId": "B"
        },
        {
          "expr": "rate(node_network_receive_drop_total{instance=\"$instance\"}[5m])",
          "legendFormat": "RX drops {{device}}",
          "refId": "C"
        },
        {
          "expr": "rate(node_network_transmit_drop_total{instance=\"$instance\"}[5m])",
          "legendFormat": "TX drops {{device}}",
          "refId": "D"
        }
      ],
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "pps",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10
          }
        }
      }
    }
  ]
}