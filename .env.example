# =============================================================================
# grafana-monitoring-stack — Environment Variables Reference
# =============================================================================
#
# SETUP INSTRUCTIONS
# ------------------
#   1. Copy this file:   cp .env.example .env
#   2. Fill in .env with your real values
#   3. Never commit .env — it is listed in .gitignore
#
# This file (.env.example) is safe to commit to git.
# It contains no real secrets — only documentation and placeholder values.
#
# GENERATING STRONG PASSWORDS
# ---------------------------
#   Linux / macOS:   openssl rand -base64 32
#   Windows:         [Convert]::ToBase64String((1..32 | %{[byte](Get-Random -Max 256)}))
#
# =============================================================================


# =============================================================================
# GRAFANA
# =============================================================================

# Username for the Grafana admin account
# Default is fine for most setups — change if your policy requires it
GRAFANA_ADMIN_USER=admin

# Password for the Grafana admin account
# Must be set — no default is applied in production
# Use: openssl rand -base64 32
GRAFANA_ADMIN_PASSWORD=


# The bare domain Grafana is served on — no protocol, no trailing slash
# Example: grafana.example.com
GF_SERVER_DOMAIN=

# The full URL Grafana is reachable at — include protocol
# Example: https://grafana.example.com
GF_SERVER_ROOT_URL=

# Set to true only when Grafana is served from a sub-path (e.g. /grafana)
# Leave false if Grafana sits at the root of its domain
GF_SERVER_SERVE_FROM_SUB_PATH=false


# =============================================================================
# PROMETHEUS
# =============================================================================

# How long Prometheus keeps metric data before discarding it
# Format: Ns (seconds) | Nm (minutes) | Nh (hours) | Nd (days) | Nw (weeks) | Ny (years)
# Recommended starting point for production: 30d
PROMETHEUS_RETENTION=15d


# =============================================================================
# ALERTMANAGER — SMTP (Gmail)
# =============================================================================
#
# This stack uses Gmail as the SMTP relay.
# You MUST use a Gmail App Password — your regular Gmail password will not work
# and would be a security risk even if it did.
#
# How to create a Gmail App Password:
#   1. Enable 2-Step Verification on your Google account
#      → https://myaccount.google.com/security
#   2. Go to App Passwords
#      → https://myaccount.google.com/apppasswords
#   3. Select app: Mail | Select device: Other → name it "alertmanager"
#   4. Copy the 16-character password shown (no spaces) into SMTP_PASSWORD below
#
# The Gmail address used here should be a dedicated alerts account,
# not a personal inbox.
# -----------------------------------------------------------------------

# The "From" address shown in alert emails
# Must match the Gmail account you are authenticating with
SMTP_FROM=

# Your Gmail address (same as SMTP_FROM in most setups)
SMTP_USERNAME=

# Gmail App Password — 16 characters, no spaces
# See instructions above — do NOT use your Gmail login password
SMTP_PASSWORD=


# =============================================================================
# ALERTMANAGER — Alert Recipients
# =============================================================================

# Recipient for warning-level and unmatched alerts
# Can be a team distribution list or shared inbox
ALERT_EMAIL_TO=

# Recipient for critical-level alerts
# Should be a pager address, on-call rotation inbox, or escalation list
# Can be the same as ALERT_EMAIL_TO if you don't have a separate on-call address
ALERT_EMAIL_TO_CRITICAL=
